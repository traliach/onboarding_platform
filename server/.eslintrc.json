{
  "root": true,
  "env": {
    "node": true,
    "es2023": true,
    "jest": true
  },
  "parserOptions": {
    "ecmaVersion": 2023,
    "sourceType": "script"
  },
  "extends": ["eslint:recommended"],
  "rules": {
    "no-console": "warn",
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "eqeqeq": ["error", "always"],
    "prefer-const": "error"
  },
  "ignorePatterns": ["node_modules/", "coverage/", "dist/"]
}
