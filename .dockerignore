# Keep the build context tiny — faster uploads, smaller cache misses,
# and fewer ways to accidentally bake secrets into a layer.
#
# Build context = repo root (see server/Dockerfile header). Anything
# unnecessary for compiling the server goes here.

**/.git
**/.gitignore

# Node
**/node_modules
**/npm-debug.log
**/.npm

# TypeScript build output — the builder stage produces its own.
**/dist
**/build
**/*.tsbuildinfo

# Env + secrets — never baked into layers.
.env
.env.*
!.env.example
**/cookies.txt
**/*.pem
**/*.key

# Editor / OS noise
**/.vscode
**/.idea
**/*.swp
**/.DS_Store
**/Thumbs.db

# Test + coverage artefacts
**/coverage
**/.nyc_output
**/__pycache__

# Large non-server trees that never belong in a server image.
# Keep client/src/types (explicitly COPY'd by the Dockerfile) but skip
# everything else in client/.
client/public
client/dist
client/node_modules
client/src/pages
client/src/components
client/src/context
client/src/api
client/src/App.tsx
client/src/main.tsx
client/src/index.css
client/index.html
client/vite.config.ts
client/tailwind.config.js
client/postcss.config.js

infra
monitoring
docs
*.md
!server/**/*.md
