[Unit]
Description=onboarding_platform API (Docker)
After=docker.service network-online.target
Requires=docker.service
Wants=network-online.target

[Service]
Type=simple
TimeoutStartSec=0
Restart=always
RestartSec=5
Environment=AWS_DEFAULT_REGION={{ aws_region }}
ExecStartPre=-/usr/bin/docker rm -f onboarding-api
ExecStartPre=/usr/bin/bash -c '/usr/bin/aws ecr get-login-password --region {{ aws_region }} | /usr/bin/docker login --username AWS --password-stdin {{ ecr_registry }}'
ExecStart=/usr/bin/docker run --name onboarding-api --rm --pull always -p 3000:3000 --env-file /etc/onboarding-platform/api.env {{ onboarding_platform_container_image }} /bin/sh -c 'node dist/server/src/db/migrate.js && exec node dist/server/src/index.js'
ExecStop=/usr/bin/docker stop onboarding-api

[Install]
WantedBy=multi-user.target
