# Base URL of the onboarding_platform API.
#
# Local development:   http://localhost:4000  (matches the server dev default)
# Vercel production:   https://api.onboarding.dominion.tech  (or whatever the ALB DNS resolves to)
#
# Must be cross-origin compatible with the server's CORS_ALLOWED_ORIGINS
# env var — the API refuses any origin not on the allow-list.
VITE_API_BASE_URL=http://localhost:4000
