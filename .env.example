# onboarding_platform — environment variables (example)
# Copy to .env for local dev. Do not commit .env.
# Every variable here is validated on startup by server/src/config/index.ts.
# The server refuses to start if any required variable is missing or invalid.

# Runtime
NODE_ENV=development              # development | test | production
APP_TARGET=api                    # api | worker — selects the process entry point
PORT=4000
LOG_LEVEL=info                    # error | warn | info | http | debug

# PostgreSQL (self-managed — see CLAUDE.md section 5)
DATABASE_URL=postgres://onboarding:onboarding@localhost:5432/onboarding

# Redis — BullMQ persistence layer
REDIS_URL=redis://localhost:6379

# BullMQ
QUEUE_NAME=client-provisioning

# Authentication — internal dashboard (JWT, section 6 + section 10)
# Minimum 32 characters. Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-at-least-thirty-two-chars-of-random-bytes

# bcrypt cost factor for admin password hashing. Minimum 12 (section 10).
BCRYPT_COST_FACTOR=12

# Client portal (public UUID token URLs, section 6)
# Base URL used in welcome emails to build per-client links: {PORTAL_BASE_URL}/{token}
PORTAL_BASE_URL=http://localhost:5173/portal

# CORS — comma-separated origins. Never "*" in production (section 10).
# Local Vite dev server default port is 5173.
CORS_ALLOWED_ORIGINS=http://localhost:5173
